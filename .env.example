# Anna's Archive base URL — domains change frequently due to legal takedowns.
# Check https://en.wikipedia.org/wiki/Anna%27s_Archive for the latest working domain.
ANNAS_BASE_URL=https://annas-archive.gl

# Anna's Archive API key — required for downloading book files.
# Get one by donating at https://annas-archive.gl/donate?r=A8V5hcf
ANNAS_API_KEY=

# How often to download new datasets (in days). Checks daily, but only
# downloads if this many days have passed since the last download.
UPDATE_INTERVAL_DAYS=30

# Import settings (0 = no limit, set a number for partial imports)
IMPORT_LIMIT=0

# API server port (change if you're using that port for something else)
PORT=3100

# Semantic search (optional) — set OLLAMA_URL to enable vector embeddings.
# Requires a running Ollama instance with the embedding model pulled.
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
